# ClothCRM Production Environment Variables (Template)
# Copy this file to .env.production and modify values for production

# FastAPI Environment Settings
ENV=production
SECRET_KEY=replace_this_with_a_secure_random_hex_string_in_production_32_chars

# Database Configuration (DigitalOcean Managed PostgreSQL Database)
# In production, DB host points to the private VPC address of your Managed DB instance
# Format: postgresql://[user]:[password]@[private-vpc-host]:25060/[database]?sslmode=require
DATABASE_URL=postgresql://doadmin:your_secure_db_password_here@private-db-user-12345-0.ondigitalocean.com:25060/clothcrm?sslmode=require
