# App Environment
ENV=development

# Security
SECRET_KEY=supersecretkeyreplaceinproduction1234567890

# Database Configuration (PostgreSQL)
# Local: postgresql://postgres:postgres@localhost:5432/clothcrm
# Docker: postgresql://postgres:postgres@db:5432/clothcrm
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/clothcrm

# Postgres container configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=clothcrm
